#!/usr/bin/env harding
#
# Basic HTTP GET example using harding-curly
# Note: Curly is auto-loaded at startup via installExternalLibraries
#

# Create a client and make a request
Client := HttpClient new.
Response := Client get: "https://httpbin.org/get".

"Status Code: " print. Response statusCode printString print.
"Response Body:" print. 
Response body print.

Client close
